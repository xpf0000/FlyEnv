<artifact-configuration xmlns="http://signpath.io/artifact-configuration/v1">
  <zip-file>
    <pe-file path="**/*.exe" min-matches="0" max-matches="unbounded">
      <authenticode-sign/>
    </pe-file>
    <pe-file path="**/*.dll" min-matches="0" max-matches="unbounded">
      <authenticode-sign/>
    </pe-file>
    <pe-file path="**/*.node" min-matches="0" max-matches="unbounded">
      <authenticode-sign/>
    </pe-file>
  </zip-file>
</artifact-configuration>
